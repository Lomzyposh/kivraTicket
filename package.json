{
  "name": "gotickets",
  "version": "1.0.0",
  "description": "Complete ticketing platform for concerts, sports, and events",
  "scripts": {
    "client": "cd client && npm run dev",
    "server": "cd server && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "keywords": [
    "tickets",
    "events",
    "booking"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.11"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.8.0"
  }
}
